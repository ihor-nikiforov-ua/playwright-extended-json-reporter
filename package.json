{
  "name": "playwright-extended-json-reporter",
  "version": "0.1.0",
  "description": "An extended JSON reporter for Playwright Test.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ihor-nikiforov-ua/playwright-extended-json-reporter.git"
  },
  "bugs": {
    "url": "https://github.com/ihor-nikiforov-ua/playwright-extended-json-reporter/issues"
  },
  "homepage": "https://github.com/ihor-nikiforov-ua/playwright-extended-json-reporter#readme",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "biome check .",
    "check:staged:write": "biome check --write --staged --no-errors-on-unmatched",
    "check:write": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "prepare": "lefthook install",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "playwright",
    "reporter",
    "json",
    "test-results"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.6.2",
    "lefthook": "2.1.6",
    "typescript": "^5.8.3"
  }
}
