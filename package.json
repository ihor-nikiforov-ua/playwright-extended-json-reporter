{
  "name": "playwright-runboard-reporter",
  "version": "0.1.0",
  "description": "A Playwright reporter that emits Runboard data bundles.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ihor-nikiforov-ua/playwright-runboard-reporter.git"
  },
  "bugs": {
    "url": "https://github.com/ihor-nikiforov-ua/playwright-runboard-reporter/issues"
  },
  "homepage": "https://github.com/ihor-nikiforov-ua/playwright-runboard-reporter#readme",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "biome check .",
    "check:staged:write": "biome check --write --staged --no-errors-on-unmatched",
    "check:write": "biome check --write .",
    "format": "biome format --write .",
    "invariants": "node scripts/check-invariants.mjs",
    "lint": "eslint .",
    "pack:verify": "npm run build && npm pack --dry-run --ignore-scripts",
    "prepare": "lefthook install",
    "prepack": "npm run build",
    "release-gate": "npm run verify && npm run test:catalog -- --fail-on-flaky-tests",
    "test": "playwright test",
    "test:catalog": "playwright test --config=playwright.catalog.config.ts",
    "test:compat": "playwright test tests/compatibility",
    "typecheck": "tsc --noEmit -p tsconfig.build.json && tsc --noEmit -p tsconfig.test.json && tsc --noEmit -p tsconfig.json",
    "verify": "npm run check && npm run lint && npm run typecheck && npm run invariants && npm test && npm run pack:verify"
  },
  "keywords": [
    "playwright",
    "reporter",
    "runboard",
    "test-results"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.59 <2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@playwright/test": "^1.59.0",
    "@types/babel__code-frame": "^7.27.0",
    "@types/node": "^24.12.3",
    "eslint": "^10.3.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "lefthook": "2.1.6",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "dependencies": {
    "@babel/code-frame": "^7.29.0"
  }
}
